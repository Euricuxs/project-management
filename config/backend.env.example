# Backend environment variables for production
# Copy this file to backend.env and update with your values

# JWT Configuration (REQUIRED - must be at least 32 characters)
JWT_SECRET=change-this-to-a-secure-secret-key-at-least-32-chars

# Database
ConnectionStrings__DefaultConnection=Data Source=/app/data/project.db

# CORS (comma-separated list of allowed origins)
CorsSettings__AllowedOrigins=http://localhost:8080,https://yourdomain.com
