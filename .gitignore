# =============================================================================
# .gitignore - Project Management SaaS
# Vue 3 + TypeScript + ASP.NET Core 10 + SQLite + Docker
# Generated for clean, maintainable version control
# =============================================================================

# -----------------------------------------------------------------------------
# .NET / ASP.NET Core
# -----------------------------------------------------------------------------

# Build artifacts
**/bin/
**/obj/
**/publish/

# User-specific build options
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# .NET specific
project.lock.json
project.fragment.lock.json
*.tsbuildinfo
DotSettings.user

# Rider .NET folders
.dotnet/
.riderFolder/

# -----------------------------------------------------------------------------
# Build Results
# -----------------------------------------------------------------------------

[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/

# -----------------------------------------------------------------------------
# Visual Studio
# -----------------------------------------------------------------------------

.vs/
*.rsuser
*.rsuseropt

# -----------------------------------------------------------------------------
# JetBrains Rider
# -----------------------------------------------------------------------------

.idea/
*.sln.imod

# -----------------------------------------------------------------------------
# Visual Studio Code
# -----------------------------------------------------------------------------

.vscode/

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------

**/node_modules/
**/dist/
**/.vite/
**/coverage/
**/.nuxt/
**/.output/
*.tsbuildinfo

# Keep package-lock.json - DO NOT IGNORE
# npm package-lock.json
package-lock.json
# pnpm lock file
pnpm-lock.yaml
# yarn lock file
yarn.lock

# -----------------------------------------------------------------------------
# SQLite Database Files
# -----------------------------------------------------------------------------

*.db
*.sqlite
*.sqlite-wal
*.sqlite-shm

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------

*.log
**/[Ll]og/
**/[Ll]ogs/

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------

.env
.env.local
.env.*.local

# Keep example config files (do NOT ignore)
# !.env.example
# !appsettings.json

# -----------------------------------------------------------------------------
# Test Results
# -----------------------------------------------------------------------------

TestResults/
**/coverage/
*.trx
*.coverage
*.coveragexml

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------

# .docker/

# -----------------------------------------------------------------------------
# Claude Code
# -----------------------------------------------------------------------------

.claude/

